)

ZMK_LAYER(num,
//  ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮   ╭─────────────┬─────────────┬─────────────┬─────────────┬─────────────╮
      XXX           &kp GRAVE     &kp LBKT      &lpar_morph   XXX               XXX           &rpar_morph   &kp RBKT      &kp BSLH      XXX
//  ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤   ├─────────────┼─────────────┼─────────────┼─────────────┼─────────────┤
      &hl LSHFT N1  &hl LALT N2   &hl LCTRL N3  &hl LGUI N4   XXX               XXX           &hr RGUI N6   &hr RCTRL N7  &hr RALT N8   &hr RSHFT N9
//  ╰─────────────┼─────────────┼─────────────┼─────────────┼─────────────╯   ╰─────────────┼─────────────┼─────────────┼─────────────┼─────────────╯
      XXX           ___           ___           &kp N5        XXX               XXX           ___           ___           ___           XXX
//                ╰─────────────┼─────────────┼─────────────┼─────────────╮   ╭─────────────┼─────────────┼─────────────┼─────────────╯
                                                ___           &kp N0       XXX  ___           ___
